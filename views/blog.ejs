<%- include('partials/head', {title: 'Blog'}) %>
<%- include('partials/navbar') %>

<div class="page-hero ph-dark">
  <div class="hero-badge" style="background:rgba(239,159,39,0.3);color:var(--gold-mid);border:1px solid rgba(239,159,39,0.4);display:inline-flex;align-items:center;gap:8px;font-size:12px;font-weight:600;padding:6px 18px;border-radius:100px;margin-bottom:18px;">
    <i data-feather="edit-3"></i> NAHIMS SW Blog
  </div>
  <h1>Blog &amp; Articles</h1>
  <p>Opinions, stories, and insights from NAHIMS SW members</p>
</div>

<div class="section">
  <div class="cards-grid">
    <% [
      {tag:'Opinion',icon:'message-circle',title:'Why HIM is the Backbone of Modern Healthcare',author:'Olamide Adesanya',date:'March 5, 2026',
        excerpt:'Health information management is not just about paperwork — it is the invisible infrastructure that keeps healthcare systems running. Without accurate records, even the best doctors are flying blind.'},
      {tag:'Informatics',icon:'cpu',title:'DHIS2 in Your Hands: What Every Nigerian HIM Student Must Know',author:'Abdulfatah Abdullahi',date:'April 18, 2026',
        excerpt:'Over 12,000 Nigerian health facilities now use DHIS2 for reporting. As HIM graduates, your ability to use this platform is no longer optional — it is a job requirement.'},
      {tag:'Career',icon:'trending-up',title:'5 Career Paths You Did Not Know Existed in HIM',author:'Toluwalope Fashola',date:'February 12, 2026',
        excerpt:'From clinical informatics to health data analytics and insurance coding — the HIM profession offers far more than hospital record rooms.'},
      {tag:'Experience',icon:'briefcase',title:'My SIWES Experience at University College Hospital Ibadan',author:'Funmi Adeola',date:'January 20, 2026',
        excerpt:'A personal account of student industrial work experience at UCH Ibadan — challenges, lessons, and career insights for every HIM student entering their IT year.'},
      {tag:'Technology',icon:'zap',title:'AI and the Future of Health Records in Nigeria',author:'Adewale Makinde',date:'May 10, 2026',
        excerpt:'Artificial intelligence is beginning to transform health documentation, coding, and clinical decision support in Nigerian hospital settings. What should HIM students prepare for?'},
      {tag:'Awareness',icon:'heart',title:'World Health Day 2026 — Why HIM Students Must Lead',author:'Fatima Ibrahim',date:'April 7, 2026',
        excerpt:"WHO's 2026 \"Stand with Science\" theme is a direct call to HIM professionals. Health data and accurate records are the scientific foundation of every health policy decision."},
      {tag:'Academics',icon:'book-open',title:'How to Ace Your HIM Exams: Study Strategies That Work',author:'Kehinde Ogunleye',date:'March 28, 2026',
        excerpt:'Practical, evidence-based study techniques specifically tailored for health information management students facing AHIMA competency standards and local professional exams.'},
      {tag:'Community',icon:'users',title:'The NEW DAWN Administration: Our Vision for NAHIMS SW',author:'NAHIMS SW Editorial',date:'June 1, 2026',
        excerpt:'What does the 2026/2027 NEW DAWN Administration stand for? Unity, academic excellence, digital transformation, and a stronger Southwest Zone that every HIM student can be proud of.'}
    ].forEach((post, i) => { %>
    <div class="card animate-on-scroll" style="animation-delay:<%= i*80 %>ms">
      <div class="card-img-placeholder">
        <i data-feather="<%= post.icon %>"></i>
      </div>
      <div class="card-body">
        <span class="card-tag"><i data-feather="<%= post.icon %>"></i> <%= post.tag %></span>
        <h3><%= post.title %></h3>
        <p><%= post.excerpt %></p>
      </div>
      <div class="card-footer">
        <span style="display:flex;align-items:center;gap:5px;font-size:11px;">
          <i data-feather="user" style="width:12px;height:12px;"></i> <%= post.author %> &middot; <%= post.date %>
        </span>
        <a href="#">Read <i data-feather="arrow-right"></i></a>
      </div>
    </div>
    <% }); %>
  </div>
</div>

<%- include('partials/footer') %>
