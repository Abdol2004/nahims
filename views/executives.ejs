<%- include('partials/head', {title: 'Executives'}) %>
<%- include('partials/navbar') %>
<%- include('partials/ticker') %>

<div class="page-hero ph-green">
  <div class="hero-badge" style="background:rgba(239,159,39,0.3);color:var(--gold-mid);border:1px solid rgba(239,159,39,0.4);display:inline-flex;align-items:center;gap:8px;font-size:12px;font-weight:700;padding:6px 18px;border-radius:100px;margin-bottom:18px;text-transform:uppercase;letter-spacing:1px;">
    <i data-feather="star"></i> NEW DAWN Administration
  </div>
  <h1>2026/2027 Leadership Team</h1>
  <p>2026/2027 NEW DAWN Administration &mdash; Comrade Ike Ekenedilichukwu Samuel, Zonal General Secretary</p>
</div>

<div class="section">
  <!-- Dropdown -->
  <div style="display:flex;justify-content:center;margin-bottom:40px;">
    <div class="exec-type-selector">
      <button class="exec-type-btn active" onclick="showExecType('main', this)">
        <i data-feather="award"></i> Main Executives
      </button>
      <button class="exec-type-btn" onclick="showExecType('appointee', this)">
        <i data-feather="briefcase"></i> Appointees
      </button>
    </div>
  </div>

  <!-- MAIN EXECUTIVES -->
  <div id="panel-main">
    <div class="section-header animate-on-scroll" style="margin-bottom:40px;">
      <div class="section-tag"><i data-feather="users"></i> Elected</div>
      <h2>Main Executives</h2>
      <p>The core elected leadership of the 2026/2027 NEW DAWN Administration</p>
    </div>
    <div class="execs-grid">
      <% mainExecs.forEach((exec, i) => { %>
      <% const isP = exec.position.toLowerCase().includes('president') && !exec.position.toLowerCase().includes('vice'); %>
      <div class="exec-card <%= isP ? 'is-president' : '' %> animate-on-scroll" style="animation-delay:<%= i*70 %>ms">
        <div class="exec-card-header">
          <div class="exec-avatar" style="background:<%= exec.color %>;">
            <% if (exec.image) { %><img src="<%= exec.image %>" alt="<%= exec.name %>"><% } else { %><%= exec.initials %><% } %>
          </div>
        </div>
        <div class="exec-card-body">
          <% if (isP) { %><div class="exec-president-badge"><i data-feather="star" style="width:9px;height:9px;"></i> Zonal President</div><% } %>
          <div class="exec-name"><%= exec.name %></div>
          <div class="exec-pos"><%= exec.position %></div>
          <div class="exec-school"><i data-feather="map-pin" style="width:10px;height:10px;"></i> <%= exec.school %></div>
        </div>
      </div>
      <% }); %>
    </div>
    <% if (!mainExecs.length) { %>
      <p style="text-align:center;color:var(--gray);padding:40px 0;">No executives added yet.</p>
    <% } %>
  </div>

  <!-- APPOINTEES -->
  <div id="panel-appointee" style="display:none;">
    <div class="section-header animate-on-scroll" style="margin-bottom:40px;">
      <div class="section-tag"><i data-feather="briefcase"></i> Appointed</div>
      <h2>Appointees</h2>
      <p>Directors and committee heads appointed by the 2026/2027 NEW DAWN Administration</p>
    </div>
    <div class="execs-grid">
      <% appointees.forEach((exec, i) => { %>
      <div class="exec-card animate-on-scroll" style="animation-delay:<%= i*70 %>ms">
        <div class="exec-card-header" style="background:linear-gradient(135deg,#0C3547,#1e5a7a);">
          <div class="exec-avatar" style="background:<%= exec.color||'var(--navy)' %>;">
            <% if (exec.image) { %><img src="<%= exec.image %>" alt="<%= exec.name %>"><% } else { %><%= exec.initials %><% } %>
          </div>
        </div>
        <div class="exec-card-body">
          <div class="exec-name"><%= exec.name %></div>
          <div class="exec-pos"><%= exec.position %></div>
          <div class="exec-school"><i data-feather="map-pin" style="width:10px;height:10px;"></i> <%= exec.school %></div>
        </div>
      </div>
      <% }); %>
    </div>
    <% if (!appointees.length) { %>
      <p style="text-align:center;color:var(--gray);padding:40px 0;">No appointees added yet.</p>
    <% } %>
  </div>
</div>

<!-- NEW DAWN Message -->
<div style="background:linear-gradient(135deg,var(--green-deeper),var(--green));color:#fff;padding:80px 1.5rem;text-align:center;">
  <div class="section" style="max-width:720px;">
    <div style="font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;opacity:0.7;margin-bottom:16px;">Office of the Zonal President</div>
    <h2 style="font-size:clamp(1.6rem,4vw,2.4rem);font-family:Tahoma,sans-serif;margin-bottom:20px;">"A New Dawn for Health Information Management Students"</h2>
    <p style="opacity:0.85;font-size:15px;line-height:1.8;margin-bottom:28px;">
      The 2026/2027 NEW DAWN Administration is committed to excellence, unity, and progress for every HIM student across the Southwest Zone. Under the leadership of Comrade Ike Ekenedilichukwu Samuel, we are building a stronger, more visible, and more impactful NAHIMS SW.
    </p>
    <div style="font-weight:700;font-size:16px;">— Comrade  Ike Ekenedilichukwu Samuel</div>
    <div style="opacity:0.7;font-size:13px;margin-top:4px;">Zonal President, NAHIMS Southwest Zone (Zone D) | 2026/2027</div>
  </div>
</div>

<script>
function showExecType(type, btn) {
  document.querySelectorAll('.exec-type-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('panel-main').style.display      = type === 'main'      ? 'block' : 'none';
  document.getElementById('panel-appointee').style.display = type === 'appointee' ? 'block' : 'none';
}
</script>

<%- include('partials/footer') %>
