<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' – ' : '' %>NAHIMS SW Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <script src="https://cdn.jsdelivr.net/npm/feather-icons/dist/feather.min.js"></script>
</head>
<body>

<!-- Mobile overlay -->
<div class="admin-overlay" id="adminOverlay" onclick="closeSidebar()"></div>

<div class="admin-layout">
  <!-- Mobile topbar -->
  <div class="admin-topbar">
    <button class="admin-hamburger" onclick="openSidebar()" aria-label="Open menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div>
      <div class="admin-topbar-logo">NAHIMS SW</div>
      <div class="admin-topbar-sub">NEW DAWN Admin</div>
    </div>
    <a href="/" target="_blank" style="margin-left:auto;color:rgba(255,255,255,0.5);display:flex;align-items:center;gap:6px;font-size:12px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      View Site
    </a>
  </div>

  <!-- Sidebar -->
  <aside class="admin-sidebar" id="adminSidebar">
    <button class="admin-sidebar-close" id="sidebarClose" onclick="closeSidebar()">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="admin-sidebar-header">
      <div class="admin-sidebar-logo">NAHIMS SW</div>
      <div class="admin-sidebar-sub">NEW DAWN Admin Panel</div>
    </div>
    <nav class="admin-nav">
      <a href="/admin" class="<%= typeof active !== 'undefined' && active === 'dashboard' ? 'active' : '' %>">
        <i data-feather="grid"></i> Dashboard
      </a>
      <div class="admin-nav-label">Content</div>
      <a href="/admin/events" class="<%= typeof active !== 'undefined' && active === 'events' ? 'active' : '' %>">
        <i data-feather="star"></i> Events
      </a>
      <a href="/admin/news" class="<%= typeof active !== 'undefined' && active === 'news' ? 'active' : '' %>">
        <i data-feather="rss"></i> News
      </a>
      <a href="/admin/executives" class="<%= typeof active !== 'undefined' && active === 'executives' ? 'active' : '' %>">
        <i data-feather="users"></i> Executives
      </a>
      <a href="/admin/chapters" class="<%= typeof active !== 'undefined' && active === 'chapters' ? 'active' : '' %>">
        <i data-feather="map-pin"></i> Chapters
      </a>
      <div class="admin-nav-label">Academic</div>
      <a href="/admin/materials" class="<%= typeof active !== 'undefined' && active === 'materials' ? 'active' : '' %>">
        <i data-feather="file-text"></i> Materials
      </a>
      <a href="/admin/videos" class="<%= typeof active !== 'undefined' && active === 'videos' ? 'active' : '' %>">
        <i data-feather="video"></i> Video Lectures
      </a>
      <div class="admin-nav-label">Sports</div>
      <a href="/admin/sports" class="<%= typeof active !== 'undefined' && active === 'sports' ? 'active' : '' %>">
        <i data-feather="award"></i> Sports & League
      </a>
      <div class="admin-nav-label">Documents</div>
      <a href="/admin/letters" class="<%= typeof active !== 'undefined' && active === 'letters' ? 'active' : '' %>">
        <i data-feather="file-text"></i> Letter Generator
      </a>
      <div class="admin-nav-label">System</div>
      <a href="/admin/settings" class="<%= typeof active !== 'undefined' && active === 'settings' ? 'active' : '' %>">
        <i data-feather="settings"></i> Site Settings
      </a>
      <a href="/" target="_blank"><i data-feather="external-link"></i> View Site</a>
      <a href="/admin/logout"><i data-feather="log-out"></i> Logout</a>
    </nav>
  </aside>

  <!-- Main -->
  <main class="admin-main">

<script>
function openSidebar() {
  document.getElementById('adminSidebar').classList.add('open');
  document.getElementById('adminOverlay').style.display = 'block';
  document.getElementById('sidebarClose').style.display = 'flex';
}
function closeSidebar() {
  document.getElementById('adminSidebar').classList.remove('open');
  document.getElementById('adminOverlay').style.display = 'none';
  document.getElementById('sidebarClose').style.display = 'none';
}
</script>
