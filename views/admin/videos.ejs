<%- include('layout-start', {title: 'Video Lectures', active: 'videos'}) %>
<div class="admin-topbar"><h1>Video Lectures</h1></div>
<% if (success) { %><div class="alert alert-success"><i data-feather="check-circle"></i> <%= success %></div><% } %>

<!-- ADD VIDEO -->
<div class="admin-card">
  <div class="admin-card-header"><h3>Add Video Lecture</h3></div>
  <form method="POST" action="/admin/videos/add">
    <div class="form-grid">
      <div class="form-group"><label class="form-label">Video Title *</label><input type="text" name="title" class="form-input" required placeholder="Introduction to EHR Systems"></div>
      <div class="form-group"><label class="form-label">Lecturer / Speaker</label><input type="text" name="lecturer" class="form-input" placeholder="Dr. Adeyemi Oluwole"></div>
    </div>
    <div class="form-grid">
      <div class="form-group"><label class="form-label">Duration</label><input type="text" name="duration" class="form-input" placeholder="45 mins"></div>
      <div class="form-group"><label class="form-label">Icon (Feather icon name)</label>
        <select name="icon" class="form-select">
          <% ['play-circle','monitor','bar-chart-2','clipboard','users','book-open','video','cpu','activity'].forEach(ic => { %>
            <option value="<%= ic %>"><%= ic %></option>
          <% }); %>
        </select>
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">YouTube Video URL</label>
      <input type="text" name="youtubeUrl" class="form-input" placeholder="https://youtu.be/... or https://www.youtube.com/watch?v=...">
      <p style="font-size:12px;color:var(--gray);margin-top:6px;"><i data-feather="info" style="display:inline;width:12px;height:12px;"></i> Leave blank if the video is not yet available. Students will see a "Coming Soon" button.</p>
    </div>
    <button type="submit" class="btn btn-green btn-sm"><i data-feather="plus"></i> Add Video Lecture</button>
  </form>
</div>

<!-- VIDEOS LIST -->
<div class="admin-card">
  <div class="admin-card-header"><h3>All Video Lectures (<%= db.videos.length %>)</h3></div>
  <% if (!db.videos.length) { %>
    <p style="color:var(--gray);text-align:center;padding:24px 0;">No video lectures added yet.</p>
  <% } else { %>
  <div class="table-wrap"><table>
    <thead><tr><th>#</th><th>Title</th><th>Lecturer</th><th>Duration</th><th>YouTube Link</th><th>Actions</th></tr></thead>
    <tbody>
      <% db.videos.forEach((v, i) => { %>
      <tr>
        <td><%= i+1 %></td>
        <td><strong><%= v.title %></strong></td>
        <td style="font-size:13px;"><%= v.lecturer || '—' %></td>
        <td style="font-size:13px;"><%= v.duration || '—' %></td>
        <td>
          <% if (v.youtubeUrl) { %>
            <a href="<%= v.youtubeUrl %>" target="_blank" style="color:var(--green);font-size:13px;display:flex;align-items:center;gap:4px;"><i data-feather="external-link" style="width:12px;height:12px;"></i> Watch</a>
          <% } else { %>
            <span style="color:var(--gray);font-size:13px;">No link</span>
          <% } %>
        </td>
        <td><div class="admin-table-actions">
          <button onclick="document.getElementById('editVid<%= v._id %>').style.display='block'" class="btn btn-green btn-xs"><i data-feather="edit-2"></i></button>
          <form method="POST" action="/admin/videos/delete/<%= v._id %>" data-confirm="Delete this video lecture?">
            <button class="btn btn-xs" style="background:#FEF2F2;color:#dc2626;border:1px solid #fecaca;"><i data-feather="trash-2"></i></button>
          </form>
        </div></td>
      </tr>
      <tr id="editVid<%= v._id %>" style="display:none;background:var(--green-light);">
        <td colspan="6" style="padding:16px;">
          <form method="POST" action="/admin/videos/update/<%= v._id %>">
            <div class="form-grid">
              <input type="text" name="title" class="form-input" value="<%= v.title %>" placeholder="Title" required>
              <input type="text" name="lecturer" class="form-input" value="<%= v.lecturer || '' %>" placeholder="Lecturer">
            </div>
            <div class="form-grid" style="margin-top:10px;">
              <input type="text" name="duration" class="form-input" value="<%= v.duration || '' %>" placeholder="Duration (e.g. 45 mins)">
              <input type="text" name="youtubeUrl" class="form-input" value="<%= v.youtubeUrl || '' %>" placeholder="YouTube URL">
            </div>
            <div style="display:flex;gap:10px;margin-top:10px;">
              <button type="submit" class="btn btn-green btn-sm"><i data-feather="save"></i> Save</button>
              <button type="button" onclick="document.getElementById('editVid<%= v._id %>').style.display='none'" class="btn btn-sm" style="background:var(--gray-mid);">Cancel</button>
            </div>
          </form>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table></div>
  <% } %>
</div>
<%- include('layout-end') %>
