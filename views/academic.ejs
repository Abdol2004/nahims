<%- include('partials/head', {title: 'Academic'}) %>
<%- include('partials/navbar') %>
<%- include('partials/ticker') %>

<div class="page-hero ph-blue">
  <div class="hero-badge" style="background:rgba(239,159,39,0.3);color:var(--gold-mid);border:1px solid rgba(239,159,39,0.4);display:inline-flex;align-items:center;gap:8px;font-size:12px;font-weight:600;padding:6px 18px;border-radius:100px;margin-bottom:18px;">
    <i data-feather="book-open"></i> Academic Hub
  </div>
  <h1>Academic Resources</h1>
  <p>Study materials, video lectures, past questions, and academic event highlights</p>
</div>

<div class="section" data-tab-group="academic">
  <div class="tab-nav">
    <button class="tab-btn active" data-tab="tab-materials"><i data-feather="file-text"></i> Study Materials</button>
    <button class="tab-btn" data-tab="tab-videos"><i data-feather="video"></i> Video Lectures</button>
    <button class="tab-btn" data-tab="tab-events"><i data-feather="calendar"></i> Academic Events</button>
  </div>

  <!-- MATERIALS -->
  <div class="tab-pane active" id="tab-materials">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;flex-wrap:wrap;gap:12px;">
      <h2 style="font-size:22px;font-weight:800;">Learning Materials</h2>
      <p style="color:var(--gray);font-size:14px;">Shared by lecturers and senior colleagues</p>
    </div>
    <div class="materials-grid">
      <% materials.forEach((m, i) => { %>
      <div class="material-card animate-on-scroll" style="animation-delay:<%= i*80 %>ms">
        <div class="material-icon"><i data-feather="<%= m.icon || 'file-text' %>"></i></div>
        <div class="material-info">
          <div class="material-cat"><%= m.category %></div>
          <h4><%= m.title %></h4>
          <p><%= m.description %></p>
          <% if (m.file) { %>
            <a href="<%= m.file %>" class="dl-btn" target="_blank" rel="noopener">
              <i data-feather="download"></i> Download
            </a>
          <% } else { %>
            <span class="dl-btn" style="opacity:0.5;cursor:not-allowed;">
              <i data-feather="clock"></i> Coming soon
            </span>
          <% } %>
        </div>
      </div>
      <% }); %>
    </div>
  </div>

  <!-- VIDEOS -->
  <div class="tab-pane" id="tab-videos">
    <h2 style="font-size:22px;font-weight:800;margin-bottom:8px;">Video Lectures</h2>
    <p style="color:var(--gray);font-size:14px;margin-bottom:28px;">Click any video to watch on YouTube</p>
    <div class="video-grid">
      <% if (videos && videos.length) { %>
        <% videos.forEach(v => { %>
        <div class="video-card animate-on-scroll">
          <% if (v.youtubeUrl) { %>
          <a href="<%= v.youtubeUrl %>" target="_blank" style="display:block;text-decoration:none;">
          <% } %>
          <div class="video-thumb">
            <div class="video-thumb-bg">
              <i data-feather="<%= v.icon || 'play-circle' %>" style="width:56px;height:56px;color:rgba(255,255,255,0.15);"></i>
            </div>
            <div class="play-circle">
              <i data-feather="<%= v.youtubeUrl ? 'play' : 'clock' %>"></i>
            </div>
          </div>
          <% if (v.youtubeUrl) { %></a><% } %>
          <div class="video-info">
            <h4><%= v.title %></h4>
            <p><%= v.lecturer %><% if (v.duration) { %> &middot; <%= v.duration %><% } %></p>
            <% if (!v.youtubeUrl) { %>
              <span style="font-size:12px;color:var(--gold-mid);font-weight:600;">Coming Soon</span>
            <% } %>
          </div>
        </div>
        <% }); %>
      <% } else { %>
        <div style="grid-column:1/-1;text-align:center;padding:60px 0;color:var(--gray);">
          <i data-feather="video" style="width:48px;height:48px;opacity:0.3;display:block;margin:0 auto 16px;"></i>
          <p>No video lectures added yet. Check back soon!</p>
        </div>
      <% } %>
    </div>
    <p style="color:var(--gray);font-size:13px;margin-top:20px;text-align:center;">
      <i data-feather="youtube" style="display:inline;width:14px;height:14px;"></i>
      Videos link to YouTube. Click any card to watch.
    </p>
  </div>

  <!-- ACADEMIC EVENTS -->
  <div class="tab-pane" id="tab-events">
    <h2 style="font-size:22px;font-weight:800;margin-bottom:8px;">Academic Events</h2>
    <p style="color:var(--gray);font-size:14px;margin-bottom:28px;">Past and upcoming academic programmes — summits, debates, workshops, live classes, and more</p>
    <div class="cards-grid">
      <% if (academicEvents && academicEvents.length) { %>
        <% academicEvents.forEach((ev, i) => { %>
        <div class="card animate-on-scroll" style="animation-delay:<%= i*100 %>ms">
          <% if (ev.image) { %>
            <div class="card-img"><img src="<%= ev.image %>" alt="<%= ev.title %>"></div>
          <% } else { %>
            <div class="card-img-placeholder">
              <i data-feather="book-open"></i>
            </div>
          <% } %>
          <div class="card-body">
            <span class="card-tag"><i data-feather="book-open" style="display:inline;width:11px;height:11px;"></i> <%= ev.category %></span>
            <h3><%= ev.title %></h3>
            <p><%= ev.description %></p>
          </div>
          <div class="card-footer">
            <span style="display:flex;align-items:center;gap:5px;"><i data-feather="calendar"></i> <%= new Date(ev.date).toLocaleDateString('en-NG', {year:'numeric',month:'long',day:'numeric'}) %></span>
            <a href="/events/<%= ev.slug %>">Details <i data-feather="arrow-right"></i></a>
          </div>
        </div>
        <% }); %>
      <% } else { %>
        <div style="grid-column:1/-1;text-align:center;padding:60px 0;color:var(--gray);">
          <i data-feather="calendar" style="width:48px;height:48px;opacity:0.3;display:block;margin:0 auto 16px;"></i>
          <p>No academic events yet. Check back soon!</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
